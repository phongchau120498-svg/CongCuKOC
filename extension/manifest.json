{
  "manifest_version": 3,
  "name": "KOC TikTok View Extractor",
  "version": "1.2",
  "description": "Tự động trích xuất và tính toán view TikTok cho công cụ đối chiếu KOC",
  "permissions": [
    "tabs",
    "windows",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*",
    "https://phongchau120498-svg.github.io/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*",
        "https://phongchau120498-svg.github.io/*",
        "file:///*"
      ],
      "js": ["content_localhost.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.tiktok.com/*"],
      "js": ["content_tiktok.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
